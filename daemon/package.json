{
  "name": "@dcouple/linear-agent-daemon",
  "version": "0.1.0",
  "packageManager": "pnpm@11.8.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "tsc",
    "generate:otel-proto": "node scripts/generate-otel-proto.mjs",
    "check:otel-proto": "node scripts/generate-otel-proto.mjs --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude test/browser.test.ts",
    "test:browser": "vitest run test/browser.test.ts",
    "test:browser-contract": "vitest run test/browser-contract.test.ts",
    "browser:smoke": "node ops/browser-smoke.mjs",
    "dev": "node --watch --enable-source-maps dist/index.js"
  },
  "dependencies": {
    "@linear/sdk": "88.1.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@playwright/mcp": "0.0.78",
    "better-sqlite3": "12.4.1",
    "protobufjs": "8.7.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.11",
    "protobufjs-cli": "2.6.1",
    "typescript": "5.9.3",
    "vitest": "4.0.17"
  }
}
